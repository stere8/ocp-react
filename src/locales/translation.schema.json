{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://twizeyimana.systems/translation.schema.json",
  "title": "Translation Schema",
  "description": "Schema for validating i18n translation files",
  "type": "object",
  "required": ["meta", "pages"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["description", "ogTitle"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 50,
          "maxLength": 160
        },
        "ogTitle": {
          "type": "string",
          "maxLength": 60
        }
      }
    },
    "pages": {
      "type": "object",
      "required": ["loading", "error", "header", "home", "about", "projects", "expertise", "ContactUs"],
      "properties": {
        "loading": {
          "type": "object",
          "required": ["message"],
          "properties": {
            "message": { "type": "string" }
          }
        },
        "error": {
          "type": "object",
          "required": ["fallbackMessage", "eyebrow", "runtimeTitle", "runtimeMessage", "notFoundTitle", "notFoundMessage", "homeCta", "contactCta", "reloadCta"],
          "properties": {
            "fallbackMessage": { "type": "string" },
            "eyebrow": { "type": "string" },
            "runtimeTitle": { "type": "string" },
            "runtimeMessage": { "type": "string" },
            "notFoundTitle": { "type": "string" },
            "notFoundMessage": { "type": "string" },
            "homeCta": { "type": "string" },
            "contactCta": { "type": "string" },
            "reloadCta": { "type": "string" }
          }
        },
        "header": {
          "type": "object",
          "required": ["BrandAlt", "NavLinks", "ScheduleButton", "DownloadDropDown", "CVOptions"],
          "properties": {
            "BrandAlt": { "type": "string" },
            "NavLinks": {
              "type": "object",
              "required": ["Services", "Projects", "Expertise", "Schedule", "Contact"],
              "properties": {
                "Services": { "type": "string" },
                "Projects": { "type": "string" },
                "Expertise": { "type": "string" },
                "Schedule": { "type": "string" },
                "Contact": { "type": "string" }
              }
            },
            "ScheduleButton": { "type": "string" },
            "DownloadDropDown": { "type": "string" },
            "CVOptions": {
              "type": "object",
              "required": ["CV_NET_EN", "CV_NET_PL", "CV_PYTHON_EN", "CV_PYTHON_PL"],
              "properties": {
                "CV_NET_EN": { "type": "string" },
                "CV_NET_PL": { "type": "string" },
                "CV_PYTHON_EN": { "type": "string" },
                "CV_PYTHON_PL": { "type": "string" }
              }
            }
          }
        },
        "home": {
          "type": "object",
          "required": ["HeroSection", "ServicesSection"],
          "properties": {
            "HeroSection": {
              "type": "object",
              "required": ["Title", "Subtitle", "ScheduleButton", "ContactButton"],
              "properties": {
                "Title": { "type": "string" },
                "Subtitle": { "type": "string" },
                "ScheduleButton": { "type": "string" },
                "ContactButton": { "type": "string" }
              }
            },
            "ServicesSection": {
              "type": "object",
              "required": ["Title", "Cards"],
              "properties": {
                "Title": { "type": "string" },
                "Cards": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["Icon", "Title", "Description"],
                    "properties": {
                      "Icon": { "type": "string" },
                      "Title": { "type": "string" },
                      "Description": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "about": {
          "type": "object",
          "required": ["AboutmeHeading", "AboutmeDescription1", "AboutmeDescription2", "AboutmeDescription3"],
          "properties": {
            "AboutmeHeading": { "type": "string" },
            "AboutmeDescription1": { "type": "string" },
            "AboutmeDescription2": { "type": "string" },
            "AboutmeDescription3": { "type": "string" }
          }
        },
        "projects": {
          "type": "object",
          "required": ["Title", "Description", "KeyFeatures", "Technologies", "Impact", "ViewOnGitHub", "ProjectList"],
          "properties": {
            "Title": { "type": "string" },
            "Description": { "type": "string" },
            "KeyFeatures": { "type": "string" },
            "Technologies": { "type": "string" },
            "Impact": { "type": "string" },
            "ViewOnGitHub": { "type": "string" },
            "ProjectList": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["Title", "Overview", "KeyFeatures", "Technologies", "Impact", "Repository"],
                "properties": {
                  "Title": { "type": "string" },
                  "Overview": { "type": "string" },
                  "KeyFeatures": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "Technologies": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "Impact": { "type": "string" },
                  "Repository": { "type": "string" }
                }
              }
            }
          }
        },
        "expertise": {
          "type": "object",
          "required": ["Title", "Intro", "Skills", "Certifications", "Industries", "ValueProposition"],
          "properties": {
            "Title": { "type": "string" },
            "Intro": { "type": "string" },
            "Skills": {
              "type": "object",
              "required": ["BackendDevelopment", "FrontendDevelopment", "DatabaseManagement", "DevOps", "ProgrammingLanguages"],
              "properties": {
                "BackendDevelopment": { "$ref": "#/definitions/skillCategory" },
                "FrontendDevelopment": { "$ref": "#/definitions/skillCategory" },
                "DatabaseManagement": { "$ref": "#/definitions/skillCategory" },
                "DevOps": { "$ref": "#/definitions/skillCategory" },
                "ProgrammingLanguages": { "$ref": "#/definitions/skillCategory" }
              }
            },
            "Certifications": {
              "type": "object",
              "required": ["Title", "Items"],
              "properties": {
                "Title": { "type": "string" },
                "Items": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "Industries": {
              "type": "object",
              "required": ["Title", "Description", "Items"],
              "properties": {
                "Title": { "type": "string" },
                "Description": { "type": "string" },
                "Items": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "ValueProposition": {
              "type": "object",
              "required": ["Title", "Description"],
              "properties": {
                "Title": { "type": "string" },
                "Description": { "type": "string" }
              }
            }
          }
        },
        "ContactUs": {
          "type": "object",
          "required": ["LetsConnectHeading", "ContactFormDescription", "contactMessage", "ContactForm"],
          "properties": {
            "LetsConnectHeading": { "type": "string" },
            "ContactFormDescription": { "type": "string" },
            "contactMessage": { "type": "string" },
            "ContactForm": {
              "type": "object",
              "required": ["YourNameLabel", "EmailLabel", "MessageLabel", "SendButton"],
              "properties": {
                "YourNameLabel": { "type": "string" },
                "EmailLabel": { "type": "string" },
                "MessageLabel": { "type": "string" },
                "SendButton": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "skillCategory": {
      "type": "object",
      "required": ["Title", "Description", "Items"],
      "properties": {
        "Title": { "type": "string" },
        "Description": { "type": "string" },
        "Items": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
